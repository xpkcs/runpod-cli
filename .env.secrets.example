# Copy to infra/secrets.env and fill in values. Never commit secrets.env.
#
# Workflow:
#   1. Fill in secrets below and save as infra/secrets.env
#   2. Send to a running pod:  task pod:send-secrets POD_ID=<id>
#      (uses scp + apply-secrets.sh)
#
# The file is sourced then deleted inside the pod.

HF_TOKEN=
WANDB_API_KEY=
