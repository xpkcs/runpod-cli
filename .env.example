# Copy to .env and fill in values. Never commit .env.
RUNPOD_API_KEY=

# Absolute path to directory containing config YAML files (pods/, templates/ subdirs)
CONFIG_DIR=

# Path to SSH private key used for pod access (task deploy / task pod:setup / rp pod ssh-cmd)
SSH_KEY=

# Path to GitHub SSH private key — uploaded to pods for git clone access
GIT_SSH_KEY=

# Branch to check out on the pod (default: main)
GIT_BRANCH=main

# RunPod Network Volume ID — create one in the RunPod UI (Storage > Network Volumes)
# before launching any pod. Network volumes persist across pod deletions and are shared
# across pods in the same datacenter. See docs/storage.md for details.
NETWORK_VOLUME_ID=

# ── Setup script hooks ──────────────────────────────────────────────────
# Path to a shell script sourced at the end of scripts/setup.sh (e.g. project-specific installs)
SETUP_SCRIPT_PATH=

# Path to a file of extra export lines appended to the persistent shell exports
EXPORTS_PATH=

# ── Field overrides (any SCREAMING_SNAKE_CASE key matching a model field) ──
# NETWORK_VOLUME_ID=vol_abc123   # → networkVolumeId
# GPU_COUNT=2                    # → gpuCount
# CONTAINER_DISK_IN_GB=50        # → containerDiskInGb
# Do NOT add ENV= (reserved field name).
